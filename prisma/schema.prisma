generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  phone     String?   @unique
  name      String
  dob       DateTime?
  address   String?
  role      Role      @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  workerProfile WorkerProfile?
  bookings      Booking[]      @relation("CustomerBookings")
  reviewsGiven  Review[]       @relation("ReviewsGiven")
  
  // New Relationships
  messagesSent      Message[]      @relation("MessagesSent")
  conversationsAsUser Conversation[] @relation("ConversationUser")
  notifications     Notification[] @relation("UserNotifications")
}

model WorkerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  skills       String[] // e.g., ["Electrician", "Plumber"]
  experience   Int      // years of experience
  locationLat  Float?
  locationLng  Float?
  locationAddress String?
  locationId   String?  @unique
  location     Location? @relation(fields: [locationId], references: [id])
  isOnline     Boolean  @default(false)
  hourlyRate   Float?
  rating       Float    @default(0.0)
  totalReviews Int      @default(0)
  
  // Jobs/Bookings handled
  jobs         Booking[] @relation("WorkerBookings")
  reviews      Review[]  @relation("WorkerReviews")
  
  // New Relationships
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  conversationsAsWorker Conversation[] @relation("ConversationWorker")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String   // Emoji or icon string
  description String?
  workers     WorkerProfile[]
}

model Location {
  id      String @id @default(uuid())
  lat     Float
  lng     Float
  address String?
  worker  WorkerProfile?
}

model Booking {
  id          String   @id @default(uuid())
  
  customerId  String
  customer    User     @relation("CustomerBookings", fields: [customerId], references: [id])
  
  workerId    String
  worker      WorkerProfile @relation("WorkerBookings", fields: [workerId], references: [id])
  
  status      BookingStatus @default(PENDING)
  jobDetails  String
  price       Float?
  
  scheduledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(uuid())
  
  rating      Int      // 1 to 5
  comment     String?
  
  reviewerId  String
  reviewer    User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  
  workerId    String
  worker      WorkerProfile @relation("WorkerReviews", fields: [workerId], references: [id])
  
  createdAt   DateTime @default(now())
}

model Conversation {
  id          String   @id @default(uuid())
  
  customerId  String
  customer    User     @relation("ConversationUser", fields: [customerId], references: [id])
  
  workerId    String
  worker      WorkerProfile @relation("ConversationWorker", fields: [workerId], references: [id])
  
  messages    Message[]
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@unique([customerId, workerId])
}

model Message {
  id              String   @id @default(uuid())
  
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId        String
  sender          User     @relation("MessagesSent", fields: [senderId], references: [id])
  
  content         String
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Notification {
  id          String   @id @default(uuid())
  
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  message     String
  type        NotificationType @default(INFO)
  isRead      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
